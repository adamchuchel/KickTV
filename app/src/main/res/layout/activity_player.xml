<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Fullscreen player -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false"
        android:focusableInTouchMode="false" />

    <!-- VOD seek overlay -->
    <LinearLayout
        android:id="@+id/seek_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:background="#CC000000"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_seek_direction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="48sp" />

        <TextView
            android:id="@+id/tv_seek_position"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_primary"
            android:textSize="20sp" />
    </LinearLayout>

    <!-- Loading / error overlay (center) -->
    <LinearLayout
        android:id="@+id/status_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:indeterminateTint="@color/kick_green" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Chat overlay — width/height/position set programmatically -->
    <FrameLayout
        android:id="@+id/chat_container"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_alignParentEnd="true"
        android:background="#C0000000"
        android:descendantFocusability="blocksDescendants"
        android:focusable="false"
        android:focusableInTouchMode="false">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_chat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:focusable="false"
            android:nestedScrollingEnabled="false"
            android:paddingBottom="4dp"
            android:paddingEnd="6dp"
            android:paddingStart="6dp"
            android:paddingTop="4dp"
            android:scrollbars="none" />
    </FrameLayout>

    <!-- Bottom bar: channel info + all controls (MENU/DOWN to toggle) -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#F2000000"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <!-- Row 1: channel info + action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_channel_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_game_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  •  "
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_viewers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/kick_green"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/btn_quality"
                    android:layout_width="100dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/btn_player_selector"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:nextFocusDown="@+id/seeker_opacity"
                    android:nextFocusRight="@+id/btn_chat_toggle"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_quality"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Auto"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kvalita"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_chat_toggle"
                    android:layout_width="100dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/btn_player_selector"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:nextFocusDown="@+id/seeker_opacity"
                    android:nextFocusLeft="@+id/btn_quality"
                    android:nextFocusRight="@+id/btn_side"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_chat_on_off"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ON"
                        android:textColor="@color/kick_green"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chat"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_h_pos"
                    android:layout_width="90dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/btn_player_selector"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:nextFocusDown="@+id/seeker_opacity"
                    android:nextFocusLeft="@+id/btn_chat_toggle"
                    android:nextFocusRight="@+id/btn_v_pos"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_h_pos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→ Vpravo"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="H pozice"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_v_pos"
                    android:layout_width="90dp"
                    android:layout_height="52dp"
                    android:background="@drawable/btn_player_selector"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:nextFocusDown="@+id/seeker_opacity"
                    android:nextFocusLeft="@+id/btn_h_pos"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_v_pos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↓ Dole"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="V pozice"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="6dp"
            android:layout_marginTop="6dp"
            android:background="#44FFFFFF" />

        <!-- Seekbar rows: UP/DOWN navigates between them, LEFT/RIGHT adjusts value -->

        <!-- Opacity -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:text="Průhlednost pozadí"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seeker_opacity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:focusable="true"
                android:max="100"
                android:nextFocusDown="@+id/seeker_width"
                android:nextFocusUp="@+id/btn_quality"
                android:progressTint="@color/kick_green"
                android:thumbTint="@color/kick_green" />

            <TextView
                android:id="@+id/tv_opacity_val"
                android:layout_width="55dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Width -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:text="Šířka chatu"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seeker_width"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:focusable="true"
                android:max="35"
                android:nextFocusDown="@+id/seeker_height"
                android:nextFocusUp="@+id/seeker_opacity"
                android:progressTint="@color/kick_green"
                android:thumbTint="@color/kick_green" />

            <TextView
                android:id="@+id/tv_width_val"
                android:layout_width="55dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Height -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:text="Výška chatu"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seeker_height"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:focusable="true"
                android:max="90"
                android:nextFocusDown="@+id/seeker_font"
                android:nextFocusUp="@+id/seeker_width"
                android:progressTint="@color/kick_green"
                android:thumbTint="@color/kick_green" />

            <TextView
                android:id="@+id/tv_height_val"
                android:layout_width="55dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Font size -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:text="Velikost písma"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seeker_font"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:focusable="true"
                android:max="10"
                android:nextFocusUp="@+id/seeker_height"
                android:progressTint="@color/kick_green"
                android:thumbTint="@color/kick_green" />

            <TextView
                android:id="@+id/tv_font_val"
                android:layout_width="55dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
