<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Fullscreen player -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false"
        android:focusableInTouchMode="false" />

    <!-- VOD seek overlay -->
    <LinearLayout
        android:id="@+id/seek_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:background="#CC000000"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_seek_direction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="48sp" />

        <TextView
            android:id="@+id/tv_seek_position"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_primary"
            android:textSize="20sp" />
    </LinearLayout>

    <!-- Loading / error overlay (center) -->
    <LinearLayout
        android:id="@+id/status_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:indeterminateTint="@color/kick_green" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Chat overlay — width/height/position set programmatically -->
    <FrameLayout
        android:id="@+id/chat_container"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_alignParentEnd="true"
        android:background="#C0000000"
        android:descendantFocusability="blocksDescendants"
        android:focusable="false"
        android:focusableInTouchMode="false">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_chat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:focusable="false"
            android:nestedScrollingEnabled="false"
            android:paddingBottom="4dp"
            android:paddingEnd="6dp"
            android:paddingStart="6dp"
            android:paddingTop="4dp"
            android:scrollbars="none" />
    </FrameLayout>

    <!-- Compact settings bar (DOWN to open, BACK to close) -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#F0000000"
        android:orientation="vertical"
        android:paddingBottom="10dp"
        android:paddingEnd="20dp"
        android:paddingStart="20dp"
        android:paddingTop="8dp"
        android:visibility="gone">

        <!-- Channel info row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/tv_channel_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_game_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_viewers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/kick_green"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Settings chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout android:id="@+id/chip_chat" style="@style/SettingChip">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Chat" android:textColor="@color/text_secondary" android:textSize="10sp" />
                    <TextView android:id="@+id/val_chat" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="ON"
                        android:textColor="@color/kick_green" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:id="@+id/chip_opacity" style="@style/SettingChip">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Průhlednost" android:textColor="@color/text_secondary" android:textSize="10sp" />
                    <TextView android:id="@+id/val_opacity" android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:id="@+id/chip_width" style="@style/SettingChip">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Šířka chatu" android:textColor="@color/text_secondary" android:textSize="10sp" />
                    <TextView android:id="@+id/val_width" android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:id="@+id/chip_height" style="@style/SettingChip">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Výška chatu" android:textColor="@color/text_secondary" android:textSize="10sp" />
                    <TextView android:id="@+id/val_height" android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:id="@+id/chip_font" style="@style/SettingChip">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Písmo" android:textColor="@color/text_secondary" android:textSize="10sp" />
                    <TextView android:id="@+id/val_font" android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:id="@+id/chip_hpos" style="@style/SettingChip">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="H pozice" android:textColor="@color/text_secondary" android:textSize="10sp" />
                    <TextView android:id="@+id/val_hpos" android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:id="@+id/chip_vpos" style="@style/SettingChip">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="V pozice" android:textColor="@color/text_secondary" android:textSize="10sp" />
                    <TextView android:id="@+id/val_vpos" android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:id="@+id/chip_quality" style="@style/SettingChip">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Kvalita" android:textColor="@color/text_secondary" android:textSize="10sp" />
                    <TextView android:id="@+id/val_quality" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Auto"
                        android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- Chat delay — only shown for live streams -->
                <LinearLayout android:id="@+id/chip_delay" style="@style/SettingChip"
                    android:visibility="gone">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Zpoždění chatu" android:textColor="@color/text_secondary" android:textSize="10sp" />
                    <TextView android:id="@+id/val_delay" android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="↑↓ hodnota  •  ←→ přepnout  •  BACK zavřít"
            android:textColor="#55FFFFFF"
            android:textSize="9sp" />

    </LinearLayout>

</RelativeLayout>
